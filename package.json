{
  "name": "demoqa-serenity-playwright",
  "version": "1.0.0",
  "description": "Automated tests for DemoQA using Playwright, TypeScript and Serenity/JS with Screenplay pattern",
  "scripts": {
    "clean": "rimraf target",
    "test": "failsafe clean test:execute test:report",
    "test:execute": "playwright test",
    "test:report": "serenity-bdd run",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug"
  },
  "keywords": [
    "playwright",
    "serenity-js",
    "screenplay",
    "typescript",
    "automation",
    "testing"
  ],
  "author": "QA Engineer",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@serenity-js/assertions": "^3.22.0",
    "@serenity-js/console-reporter": "^3.22.0",
    "@serenity-js/core": "^3.22.0",
    "@serenity-js/playwright": "^3.22.0",
    "@serenity-js/playwright-test": "^3.22.0",
    "@serenity-js/serenity-bdd": "^3.22.0",
    "@serenity-js/web": "^3.22.0",
    "@types/node": "^20.11.0",
    "npm-failsafe": "^1.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  }
}
